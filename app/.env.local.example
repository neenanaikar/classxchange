# Embedded wallet provider — sign up at https://privy.io, create an app, and
# paste its App ID here. Without this, login/wallet creation won't work.
NEXT_PUBLIC_PRIVY_APP_ID=

# Chain + contract addresses. These defaults point at a local Anvil chain
# (anvil running on 127.0.0.1:8545) using the addresses from
# `forge script script/Deploy.s.sol --broadcast`.
NEXT_PUBLIC_CHAIN_ID=31337
NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545
NEXT_PUBLIC_CLASS_ESCROW_ADDRESS=
NEXT_PUBLIC_USDC_ADDRESS=
