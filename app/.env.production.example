# Template for the hosted (Railway) deployment — copy these into Railway's
# environment variable settings, not into a committed file.

# Same Privy app as local dev — Privy supports multiple chains per app,
# just make sure Base Sepolia is added under supported chains/networks in
# the Privy dashboard.
NEXT_PUBLIC_PRIVY_APP_ID=cmrk8q3zo001x0cjrgq1tyeaz

# Base Sepolia
NEXT_PUBLIC_CHAIN_ID=84532
NEXT_PUBLIC_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_CLASS_ESCROW_ADDRESS=0x26294F3baF2D7289f1eEfDEd7d4df8d21d1fC1a4
NEXT_PUBLIC_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Postgres connection string — Railway provisions this automatically when
# you attach a Postgres plugin (available as ${{Postgres.DATABASE_URL}}).
DATABASE_URL=
